# 知识库发布配置示例
# 将此文件复制到知识库根目录，重命名为 .knowledge-publish.yaml

# ============================================
# 默认发布规则
# ============================================
# true: 所有文章默认公开（推荐）
# false: 所有文章默认隐藏，需要手动指定公开
defaultPublished: true

# ============================================
# 公开目录（强制公开）
# ============================================
# 当 defaultPublished: false 时，指定哪些目录公开
# publicDirs:
#   - blog
#   - notes/public
#   - projects

# ============================================
# 隐藏目录（强制隐藏）
# ============================================
# 这些目录不会出现在网站文件树中
# ignoreDirs:
#   - drafts
#   - private
#   - archive
#   - secrets

# ============================================
# 隐藏文件模式
# ============================================
# 匹配这些模式的文件不会显示
# 支持 * 通配符
# ignorePatterns:
#   - "README.md"
#   - "*.draft.md"
#   - "*.private.md"
#   - "_*"